    function countWords(text) {
      const cleanedText = text.trim();

      if (cleanedText === "") {
        return 0;
      }

      return cleanedText.split(/\s+/).length;
    }

    function getCompleteLabel(checkbox) {
      return checkbox.closest(".complete-label");
    }

    function openPhotoDatabase() {
      return new Promise((resolve, reject) => {
        const request = indexedDB.open(
          photoDatabaseName,
          photoDatabaseVersion
        );

        request.onupgradeneeded = () => {
          const database = request.result;

          if (!database.objectStoreNames.contains(photoStoreName)) {
            database.createObjectStore(photoStoreName);
          }
        };

        request.onsuccess = () => resolve(request.result);
        request.onerror = () => reject(request.error);
      });
    }

    async function savePhoto(photoId, file) {
      const database = await openPhotoDatabase();

      return new Promise((resolve, reject) => {
        const transaction = database.transaction(
          photoStoreName,
          "readwrite"
        );

        transaction.objectStore(photoStoreName).put(file, photoId);

        transaction.oncomplete = () => {
          database.close();
          resolve();
        };

        transaction.onerror = () => {
          database.close();
          reject(transaction.error);
        };
      });
    }

    async function loadPhoto(photoId) {
      const database = await openPhotoDatabase();

      return new Promise((resolve, reject) => {
        const transaction = database.transaction(
          photoStoreName,
          "readonly"
        );

        const request = transaction
          .objectStore(photoStoreName)
          .get(photoId);

        request.onsuccess = () => resolve(request.result || null);
        request.onerror = () => reject(request.error);

        transaction.oncomplete = () => database.close();
      });
    }

    async function deletePhoto(photoId) {
      const database = await openPhotoDatabase();

      return new Promise((resolve, reject) => {
        const transaction = database.transaction(
          photoStoreName,
          "readwrite"
        );

        transaction.objectStore(photoStoreName).delete(photoId);

        transaction.oncomplete = () => {
          database.close();
          resolve();
        };

        transaction.onerror = () => {
          database.close();
          reject(transaction.error);
        };
      });
    }

    function setPhotoPreview(photoBox, file) {
      const previewWrap = photoBox.querySelector(".photo-preview-wrap");
      const preview = photoBox.querySelector(".photo-preview");
      const status = photoBox.querySelector(".photo-status");

      if (preview.dataset.objectUrl) {
        URL.revokeObjectURL(preview.dataset.objectUrl);
      }

      if (file) {
        const objectUrl = URL.createObjectURL(file);

        preview.src = objectUrl;
        preview.dataset.objectUrl = objectUrl;
        previewWrap.classList.add("has-photo");

        photoBox.dataset.hasPhoto = "true";

        status.textContent = "Fotografie je uložená v tomto telefonu.";
        status.classList.add("saved");
        status.classList.remove("error");
      } else {
        preview.removeAttribute("src");
        delete preview.dataset.objectUrl;
        previewWrap.classList.remove("has-photo");

        photoBox.dataset.hasPhoto = "false";

        status.textContent = "Fotografie zatím není vložená.";
        status.classList.remove("saved", "error");
      }
    }

    function updateAnswerAppearance(field) {
      const maxWords = Number(field.dataset.maxWords || 0);
      const wordCount = countWords(field.value);
      const isOverLimit = maxWords > 0 && wordCount > maxWords;

      field.classList.toggle("too-many-words", isOverLimit);

      const answerBox = field.closest(".answer-box");
      const counter = answerBox.querySelector(".word-counter");
      const warning = answerBox.querySelector(".limit-warning");

      if (counter && maxWords > 0) {
        counter.textContent = `${wordCount} / ${maxWords} slov`;
        counter.classList.toggle("limit-reached", isOverLimit);
      }

      if (warning) {
        if (isOverLimit) {
          warning.textContent =
            `Zkraťte odpověď na nejvýše ${maxWords} slov. Potom půjde úkol označit jako splněný.`;

          warning.classList.add("show");
        } else {
          warning.classList.remove("show");
        }
      }
    }

    function taskCanBeCompleted(taskContent) {
      const taskAnswers = [
        ...taskContent.querySelectorAll(".task-answer")
      ];

      const requiredPhotos = [
        ...taskContent.querySelectorAll(
          '.photo-box[data-photo-required="true"]'
        )
      ];

      const answersAreValid = taskAnswers.every(field => {
        const maxWords = Number(field.dataset.maxWords || 0);
        const wordCount = countWords(field.value);
        const hasText = field.value.trim().length >= 1;
        const isWithinLimit =
          maxWords === 0 || wordCount <= maxWords;

        return hasText && isWithinLimit;
      });

      const photosAreValid = requiredPhotos.every(
        photoBox => photoBox.dataset.hasPhoto === "true"
      );

      return answersAreValid && photosAreValid;
    }

    function validateTask(taskContent) {
      const checkbox = taskContent.querySelector(".task-check");
      const completeLabel = getCompleteLabel(checkbox);
      const canComplete = taskCanBeCompleted(taskContent);

      if (!canComplete) {
        checkbox.checked = false;
        checkbox.disabled = true;
        completeLabel.classList.add("is-disabled");

        checkbox
          .closest(".task-card")
          .classList.remove("is-complete");
      } else {
        checkbox.disabled = false;
        completeLabel.classList.remove("is-disabled");
      }
    }

    function validateAllTasks() {
      document.querySelectorAll(".task-content").forEach(
        taskContent => validateTask(taskContent)
      );
    }

    function saveAnswers() {
      const answers = {};

      answerFields.forEach(field => {
        answers[field.dataset.answerId] = field.value;
      });

      localStorage.setItem(
        answersStorageKey,
        JSON.stringify(answers)
      );
    }

    function loadAnswers() {
      const savedAnswers = JSON.parse(
        localStorage.getItem(answersStorageKey) || "{}"
      );

      answerFields.forEach(field => {
        const answerId = field.dataset.answerId;

        if (Object.prototype.hasOwnProperty.call(savedAnswers, answerId)) {
          field.value = savedAnswers[answerId];
        }

        updateAnswerAppearance(field);
      });
    }

    async function initializePhotoBox(photoBox) {
      const photoId = photoBox.dataset.photoId;
      const inputs = [...photoBox.querySelectorAll(".photo-input")];
      const deleteButton = photoBox.querySelector(".photo-delete");
      const status = photoBox.querySelector(".photo-status");
      const taskContent = photoBox.closest(".task-content");

      photoBox.dataset.hasPhoto = "false";

      try {
        const savedPhoto = await loadPhoto(photoId);
        setPhotoPreview(photoBox, savedPhoto);
      } catch (error) {
        console.error(error);
        status.textContent =
          "Fotografii se nepodařilo načíst. Zkuste ji vložit znovu.";
        status.classList.add("error");
      }

      validateTask(taskContent);

      inputs.forEach(input => {
        input.addEventListener("change", async () => {
          const file = input.files && input.files[0];

          if (!file) {
            return;
          }

          if (!file.type.startsWith("image/")) {
            status.textContent = "Vybraný soubor není fotografie.";
            status.classList.add("error");
            input.value = "";
            return;
          }

          status.textContent = "Fotografie se ukládá…";
          status.classList.remove("saved", "error");

          try {
            await savePhoto(photoId, file);
            setPhotoPreview(photoBox, file);
          } catch (error) {
            console.error(error);
            status.textContent =
              "Fotografii se nepodařilo uložit. Zkuste menší snímek nebo uvolněte místo v telefonu.";
            status.classList.add("error");
          }

          input.value = "";
          validateTask(taskContent);
          updateProgress();
        });
      });

      deleteButton.addEventListener("click", async () => {
        try {
          await deletePhoto(photoId);
          setPhotoPreview(photoBox, null);
        } catch (error) {
          console.error(error);
          status.textContent =
            "Fotografii se nepodařilo odstranit.";
          status.classList.add("error");
        }

        validateTask(taskContent);
        updateProgress();
      });
    }



    function lockApplication(receipt) {
      document.body.classList.add("app-locked");

      teamNameInput.disabled = true;
      teamMembersInput.disabled = true;
      submitResultsButton.disabled = true;

      answerFields.forEach(field => {
        field.disabled = true;
      });

      checks.forEach(checkbox => {
        checkbox.disabled = true;
      });

      document.querySelectorAll(".photo-input").forEach(input => {
        input.disabled = true;
      });

      document.querySelectorAll(".photo-button").forEach(button => {
        button.setAttribute("aria-disabled", "true");
      });

      document.querySelectorAll(".photo-delete").forEach(button => {
        button.disabled = true;
      });

      lockedBanner.classList.add("show");
      newGameButton.classList.add("show");

      lockedBannerText.textContent =
        ` Tým „${receipt.teamName}“, kód odevzdání ${receipt.code}.`;
    }

    async function clearAllStoredPhotos() {
      const database = await openPhotoDatabase();

      return new Promise((resolve, reject) => {
        const transaction = database.transaction(
          photoStoreName,
          "readwrite"
        );

        transaction.objectStore(photoStoreName).clear();

        transaction.oncomplete = () => {
          database.close();
          resolve();
        };

        transaction.onerror = () => {
          database.close();
          reject(transaction.error);
        };
      });
    }

    async function startNewGame() {
      const confirmed = window.confirm(
        "Opravdu chcete vymazat všechny odpovědi, fotky, zaškrtnuté úkoly a údaje týmu? Tato akce nejde vrátit."
      );

      if (!confirmed) {
        return;
      }

      newGameButton.disabled = true;
      newGameButton.textContent = "Mažu data…";

      try {
        localStorage.removeItem(tasksStorageKey);
        localStorage.removeItem(answersStorageKey);
        localStorage.removeItem(teamStorageKey);
        localStorage.removeItem(lastSubmissionStorageKey);

        await clearAllStoredPhotos();

        window.location.reload();
      } catch (error) {
        console.error(error);
        newGameButton.disabled = false;
        newGameButton.textContent = "Začít novou hru a vymazat data";

        showSubmitStatus(
          "error",
          "Data se nepodařilo úplně vymazat. Zkuste stránku obnovit a akci zopakovat."
        );
      }
    }

    function saveTeamInfo() {
      const teamInfo = {
        teamName: teamNameInput.value,
        teamMembers: teamMembersInput.value
      };

      localStorage.setItem(
        teamStorageKey,
        JSON.stringify(teamInfo)
      );
    }

    function loadTeamInfo() {
      const savedTeam = JSON.parse(
        localStorage.getItem(teamStorageKey) || "{}"
      );

      teamNameInput.value = savedTeam.teamName || "";
      teamMembersInput.value = savedTeam.teamMembers || "";
    }

    function getCurrentAnswers() {
      const answers = {};

      answerFields.forEach(field => {
        const value = field.value.trim();

        if (value !== "") {
          answers[field.dataset.answerId] = value;
        }
      });

      return answers;
    }

    function getCompletedTasks() {
      return taskDefinitions.map((task, index) => ({
        id: task.id,
        title: task.title,
        completed: Boolean(
          checks[index] &&
          checks[index].checked &&
          !checks[index].disabled
        )
      }));
    }

    function getLocalPhotoCount() {
      return photoBoxes.filter(
        photoBox => photoBox.dataset.hasPhoto === "true"
      ).length;
    }

    function updateSubmissionSummary() {
      submitCompletedCount.textContent = checks.filter(
        checkbox => checkbox.checked && !checkbox.disabled
      ).length;

      submitAnswerCount.textContent = Object.keys(
        getCurrentAnswers()
      ).length;

      submitPhotoCount.textContent = getLocalPhotoCount();
    }

    function showSubmitStatus(type, message, receiptCode = "") {
      submitStatus.className = `submit-status show ${type}`;
      submitStatus.innerHTML = "";

      const messageLine = document.createElement("div");
      messageLine.textContent = message;
      submitStatus.appendChild(messageLine);

      if (receiptCode) {
        const receipt = document.createElement("div");
        receipt.className = "receipt";
        receipt.textContent = `Kód odevzdání: ${receiptCode}`;
        submitStatus.appendChild(receipt);
      }
    }

    function createSubmissionCode() {
      const alphabet = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
      let randomPart = "";

      for (let index = 0; index < 6; index += 1) {
        const randomIndex = crypto.getRandomValues(
          new Uint32Array(1)
        )[0] % alphabet.length;

        randomPart += alphabet[randomIndex];
      }

      return `PLZ-${randomPart}`;
    }

    function getFileExtension(mimeType) {
      if (mimeType === "image/png") {
        return "png";
      }

      if (mimeType === "image/webp") {
        return "webp";
      }

      return "jpg";
    }

    async function compressPhoto(file) {
      const imageBitmap = await createImageBitmap(file);
      const maxDimension = 1600;

      let width = imageBitmap.width;
      let height = imageBitmap.height;

      if (width > maxDimension || height > maxDimension) {
        const scale = Math.min(
          maxDimension / width,
          maxDimension / height
        );

        width = Math.round(width * scale);
        height = Math.round(height * scale);
      }

      const canvas = document.createElement("canvas");
      canvas.width = width;
      canvas.height = height;

      const context = canvas.getContext("2d", {
        alpha: false
      });

      context.drawImage(
        imageBitmap,
        0,
        0,
        width,
        height
      );

      imageBitmap.close();

      return new Promise((resolve, reject) => {
        canvas.toBlob(
          blob => {
            if (blob) {
              resolve(blob);
            } else {
              reject(
                new Error("Fotografii se nepodařilo zmenšit.")
              );
            }
          },
          "image/jpeg",
          0.78
        );
      });
    }

    async function uploadSubmissionPhotos(submissionId) {
      const photoPaths = {};
      const photosToUpload = photoBoxes.filter(
        photoBox => photoBox.dataset.hasPhoto === "true"
      );

      for (
        let index = 0;
        index < photosToUpload.length;
        index += 1
      ) {
        const photoBox = photosToUpload[index];
        const photoId = photoBox.dataset.photoId;

        showSubmitStatus(
          "working",
          `Odesílání fotografií ${index + 1} / ${photosToUpload.length}…`
        );

        const localPhoto = await loadPhoto(photoId);

        if (!localPhoto) {
          throw new Error(
            `Fotografie „${photoId}“ nebyla v telefonu nalezena.`
          );
        }

        const compressedPhoto = await compressPhoto(localPhoto);
        const extension = getFileExtension(compressedPhoto.type);
        const storagePath =
          `${submissionId}/${photoId}.${extension}`;

        const { error } = await supabaseClient
          .storage
          .from("team-photos")
          .upload(storagePath, compressedPhoto, {
            contentType: compressedPhoto.type,
            cacheControl: "3600",
            upsert: false
          });

        if (error) {
          throw error;
        }

        photoPaths[photoId] = storagePath;
      }

      return photoPaths;
    }


    function showPreSubmitSummary() {
      const teamName = teamNameInput.value.trim();

      if (teamName === "") {
        teamNameInput.focus();

        showSubmitStatus(
          "error",
          "Nejdříve vyplňte název týmu."
        );

        return;
      }

      const completedTasks = getCompletedTasks();
      const completedCount = completedTasks.filter(
        task => task.completed
      ).length;

      const answerCount = Object.keys(
        getCurrentAnswers()
      ).length;

      const photoCount = getLocalPhotoCount();

      reviewCompletedCount.textContent = completedCount;
      reviewAnswerCount.textContent = answerCount;
      reviewPhotoCount.textContent = photoCount;

      missingTasksList.innerHTML = "";

      const missingTasks = completedTasks.filter(
        task => !task.completed
      );

      if (missingTasks.length === 0) {
        const item = document.createElement("li");
        item.textContent = "Žádné – všechny úkoly jsou označené jako splněné.";
        missingTasksList.appendChild(item);
      } else {
        missingTasks.forEach(task => {
          const item = document.createElement("li");
          item.textContent = task.title;
          missingTasksList.appendChild(item);
        });
      }

      hideSubmitStatus();
      preSubmitSummary.classList.add("show");

      preSubmitSummary.scrollIntoView({
        behavior: "smooth",
        block: "center"
      });
    }

    function hidePreSubmitSummary() {
      preSubmitSummary.classList.remove("show");
    }

    function hideSubmitStatus() {
      submitStatus.className = "submit-status";
      submitStatus.textContent = "";
    }

    async function submitResults() {
      const teamName = teamNameInput.value.trim();
      const teamMembers = teamMembersInput.value.trim();

      if (teamName === "") {
        teamNameInput.focus();

        showSubmitStatus(
          "error",
          "Nejdříve vyplňte název týmu."
        );

        return;
      }

      if (!navigator.onLine) {
        showSubmitStatus(
          "error",
          "Telefon není připojený k internetu. Připojte se a zkuste odeslání znovu."
        );

        return;
      }

      const previousSubmission = JSON.parse(
        localStorage.getItem(lastSubmissionStorageKey) || "null"
      );

      if (previousSubmission) {
        const sendAgain = window.confirm(
          `Tento telefon už jednou odevzdal výsledky s kódem ${previousSubmission.code}. Opravdu chcete vytvořit nové odevzdání?`
        );

        if (!sendAgain) {
          return;
        }
      }

      submitResultsButton.disabled = true;
      saveTeamInfo();

      const submissionId = crypto.randomUUID();
      const submissionCode = createSubmissionCode();
      const completedTasks = getCompletedTasks();
      const completedCount = completedTasks.filter(
        task => task.completed
      ).length;

      try {
        showSubmitStatus(
          "working",
          "Připravuji výsledky k odeslání…"
        );

        const photoPaths = await uploadSubmissionPhotos(
          submissionId
        );

        showSubmitStatus(
          "working",
          "Ukládám odpovědi a výsledky…"
        );

        const { error } = await supabaseClient
          .from("submissions")
          .insert({
            id: submissionId,
            submission_code: submissionCode,
            team_name: teamName,
            team_members: teamMembers || null,
            completed_count: completedCount,
            total_count: taskDefinitions.length,
            completed_tasks: completedTasks,
            answers: getCurrentAnswers(),
            photo_paths: photoPaths,
            app_version: "1.0-supabase"
          });

        if (error) {
          throw error;
        }

        const receipt = {
          id: submissionId,
          code: submissionCode,
          teamName,
          submittedAt: new Date().toISOString()
        };

        localStorage.setItem(
          lastSubmissionStorageKey,
          JSON.stringify(receipt)
        );

        showSubmitStatus(
          "success",
          `Výsledky týmu „${teamName}“ byly úspěšně odeslány organizátorovi.`,
          submissionCode
        );

        hidePreSubmitSummary();
        lockApplication(receipt);
      } catch (error) {
        console.error(error);

        showSubmitStatus(
          "error",
          `Odeslání se nepodařilo: ${error.message || "Neznámá chyba"}. Zkontrolujte internet a zkuste to znovu.`
        );
      } finally {
        const isLocked = Boolean(
          localStorage.getItem(lastSubmissionStorageKey)
        );

        if (!isLocked) {
          submitResultsButton.disabled = false;
        }
      }
    }

    function loadProgress() {
      const saved = JSON.parse(
        localStorage.getItem(tasksStorageKey) || "[]"
      );

      checks.forEach((checkbox, index) => {
        if (!checkbox.disabled) {
          checkbox.checked = Boolean(saved[index]);
        }

        checkbox
          .closest(".task-card")
          .classList.toggle(
            "is-complete",
            checkbox.checked && !checkbox.disabled
          );
      });

      updateProgress();
    }

    function updateProgress() {
      const completed = checks.filter(
        checkbox => checkbox.checked && !checkbox.disabled
      ).length;

      const total = checks.length;
      const percentage = total ? (completed / total) * 100 : 0;

      progressText.textContent = `${completed} / ${total}`;
      progressBar.style.width = `${percentage}%`;

      const remaining = total - completed;

      if (remaining === 0) {
        remainingTasksText.textContent =
          "Máte označené všechny úkoly jako splněné.";
        nextIncompleteButton.disabled = true;
        nextIncompleteButton.textContent = "Vše dokončeno";
      } else {
        remainingTasksText.textContent =
          `Zbývá dokončit ${remaining} ${
            remaining === 1
              ? "úkol"
              : remaining >= 2 && remaining <= 4
                ? "úkoly"
                : "úkolů"
          }.`;

        nextIncompleteButton.disabled = false;
        nextIncompleteButton.textContent =
          "Najít první nesplněný";
      }

      const state = checks.map(
        checkbox => checkbox.checked && !checkbox.disabled
      );

      localStorage.setItem(
        tasksStorageKey,
        JSON.stringify(state)
      );

      updateSubmissionSummary();
    }

    answerFields.forEach(field => {
      field.addEventListener("input", () => {
        hidePreSubmitSummary();
        updateAnswerAppearance(field);
        saveAnswers();

        validateTask(
          field.closest(".task-content")
        );

        updateProgress();
      });
    });

    teamNameInput.addEventListener("input", () => {
      saveTeamInfo();
      hidePreSubmitSummary();
    });

    teamMembersInput.addEventListener("input", () => {
      saveTeamInfo();
      hidePreSubmitSummary();
    });

    nextIncompleteButton.addEventListener(
      "click",
      scrollToFirstIncompleteTask
    );

    backToTopButton.addEventListener("click", () => {
      window.scrollTo({
        top: 0,
        behavior: "smooth"
      });
    });

    window.addEventListener(
      "scroll",
      updateBackToTopVisibility,
      { passive: true }
    );

    submitResultsButton.addEventListener(
      "click",
      showPreSubmitSummary
    );

    cancelSubmitButton.addEventListener(
      "click",
      hidePreSubmitSummary
    );

    confirmSubmitButton.addEventListener(
      "click",
      submitResults
    );

    newGameButton.addEventListener(
      "click",
      startNewGame
    );

    checks.forEach(checkbox => {
      checkbox.addEventListener("change", () => {
        hidePreSubmitSummary();
        checkbox
          .closest(".task-card")
          .classList.toggle(
            "is-complete",
            checkbox.checked && !checkbox.disabled
          );

        updateProgress();
      });
    });

    async function startApp() {
      updateCountdown();
      updateBackToTopVisibility();

      window.setInterval(
        updateCountdown,
        1000
      );

      loadTeamInfo();
      loadAnswers();
      validateAllTasks();

      await Promise.all(
        photoBoxes.map(photoBox => initializePhotoBox(photoBox))
      );

      validateAllTasks();
      loadProgress();
      updateSubmissionSummary();

      const previousSubmission = JSON.parse(
        localStorage.getItem(lastSubmissionStorageKey) || "null"
      );

      if (previousSubmission) {
        showSubmitStatus(
          "success",
          `Z tohoto telefonu už byly odeslány výsledky týmu „${previousSubmission.teamName}“.`,
          previousSubmission.code
        );

        lockApplication(previousSubmission);
      }
    }

    startApp();
  </script>
