<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#244f38">

  <title>Přežij PLZEŇ</title>

  <style>
    :root {
      --bg: #f4f5f7;
      --card: #ffffff;
      --text: #222222;
      --muted: #62656b;
      --primary: #6f2dbd;
      --primary-light: #f0e7ff;
      --border: #e6e7eb;
      --success: #218739;
      --danger: #b42318;
      --danger-light: #fff1ef;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.55;
    }

    button,
    input,
    textarea,
    summary {
      font: inherit;
    }

    .page {
      width: min(100% - 24px, 720px);
      margin: 0 auto;
      padding: 20px 0 48px;
    }

    .hero {
      background: linear-gradient(135deg, #ffffff, #f5edff);
      border-radius: 22px;
      padding: 24px;
      margin-bottom: 18px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    }

    h1 {
      margin: 0 0 8px;
      font-size: clamp(2rem, 8vw, 3rem);
      line-height: 1.1;
    }

    .intro {
      margin: 0;
      color: var(--muted);
    }


    .countdown-box {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 14px;
      margin-top: 18px;
      padding: 14px;
      border-radius: 14px;
      background: #ffffff;
      border: 1px solid rgba(111, 45, 189, 0.2);
    }

    .countdown-label {
      display: block;
      color: var(--muted);
      font-size: 0.88rem;
    }

    .countdown-time {
      display: block;
      margin-top: 2px;
      font-size: 1.5rem;
      font-weight: 900;
      color: var(--primary);
      font-variant-numeric: tabular-nums;
    }

    .countdown-box.expired {
      border-color: rgba(180, 35, 24, 0.4);
      background: var(--danger-light);
    }

    .countdown-box.expired .countdown-time {
      color: var(--danger);
    }

    .countdown-deadline {
      text-align: right;
      font-weight: 800;
      white-space: nowrap;
    }

    .remaining-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-top: 12px;
    }

    .remaining-text {
      color: var(--muted);
      font-size: 0.92rem;
    }

    .next-task-button {
      min-height: 40px;
      padding: 8px 11px;
      border: 1px solid var(--primary);
      border-radius: 10px;
      background: #ffffff;
      color: var(--primary);
      font-weight: 800;
    }

    .info-list {
      display: grid;
      gap: 12px;
      margin-bottom: 18px;
    }

    .info-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 18px;
      overflow: hidden;
      box-shadow: 0 4px 14px rgba(0, 0, 0, 0.06);
    }

    .info-card[open] {
      border-color: rgba(111, 45, 189, 0.35);
    }

    .info-summary {
      display: flex;
      align-items: center;
      gap: 12px;
      min-height: 66px;
      padding: 15px 18px;
      cursor: pointer;
      list-style: none;
      user-select: none;
    }

    .info-summary::-webkit-details-marker {
      display: none;
    }

    .info-icon {
      width: 40px;
      height: 40px;
      display: grid;
      place-items: center;
      flex-shrink: 0;
      border-radius: 12px;
      background: var(--primary-light);
      font-size: 1.3rem;
    }

    .info-title {
      flex: 1;
      font-weight: 900;
      font-size: 1.05rem;
    }

    .info-arrow {
      color: var(--primary);
      font-size: 1.25rem;
      transition: transform 0.2s ease;
    }

    .info-card[open] .info-arrow {
      transform: rotate(180deg);
    }

    .info-content {
      padding: 0 18px 18px;
      border-top: 1px solid var(--border);
    }

    .rules-list,
    .places-list {
      margin: 14px 0 0;
      padding-left: 22px;
    }

    .rules-list li,
    .places-list li {
      margin-bottom: 8px;
    }

    .map-image {
      display: block;
      width: 100%;
      height: auto;
      margin-top: 16px;
      border: 1px solid var(--border);
      border-radius: 14px;
      background: #eceef2;
    }

    .map-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      min-height: 48px;
      margin-top: 12px;
      padding: 10px 14px;
      border-radius: 12px;
      background: var(--primary);
      color: #ffffff;
      font-weight: 800;
      text-decoration: none;
    }

    .map-note,
    .help-note {
      margin: 12px 0 0;
      color: var(--muted);
      font-size: 0.9rem;
    }

    .back-to-top {
      position: fixed;
      right: 16px;
      bottom: 16px;
      z-index: 20;
      display: none;
      align-items: center;
      justify-content: center;
      width: 50px;
      height: 50px;
      border: 0;
      border-radius: 50%;
      background: var(--primary);
      color: #ffffff;
      font-size: 1.25rem;
      font-weight: 900;
      box-shadow: 0 7px 20px rgba(0, 0, 0, 0.22);
    }

    .back-to-top.show {
      display: flex;
    }

    @media (max-width: 520px) {
      .countdown-box {
        grid-template-columns: 1fr;
      }

      .countdown-deadline {
        text-align: left;
      }

      .remaining-row {
        align-items: stretch;
        flex-direction: column;
      }
    }


    .save-info {
      margin: 14px 0 0;
      color: var(--muted);
      font-size: 0.88rem;
    }

    .progress-box {
      margin-top: 20px;
      padding-top: 18px;
      border-top: 1px solid rgba(111, 45, 189, 0.18);
    }

    .progress-row {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 8px;
      font-weight: 700;
    }

    .progress-track {
      height: 12px;
      overflow: hidden;
      background: #dedfe4;
      border-radius: 999px;
    }

    .progress-bar {
      width: 0;
      height: 100%;
      background: var(--primary);
      border-radius: inherit;
      transition: width 0.25s ease;
    }

    .task-list {
      display: grid;
      gap: 14px;
    }

    .task-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 18px;
      overflow: hidden;
      box-shadow: 0 4px 14px rgba(0, 0, 0, 0.06);
    }

    .task-card[open] {
      border-color: rgba(111, 45, 189, 0.35);
    }

    .task-card.is-complete {
      border-color: rgba(33, 135, 57, 0.5);
    }

    .task-summary {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 18px;
      cursor: pointer;
      list-style: none;
      user-select: none;
    }

    .task-summary::-webkit-details-marker {
      display: none;
    }

    .task-summary:focus-visible {
      outline: 3px solid rgba(111, 45, 189, 0.3);
      outline-offset: -3px;
    }

    .task-icon {
      flex: 0 0 auto;
      width: 42px;
      height: 42px;
      display: grid;
      place-items: center;
      border-radius: 12px;
      background: var(--primary-light);
      font-size: 1.4rem;
    }

    .task-card.is-complete .task-icon {
      background: #e7f6eb;
    }

    .task-heading {
      flex: 1;
      min-width: 0;
    }

    .task-title {
      display: block;
      font-size: 1.08rem;
      font-weight: 800;
      line-height: 1.25;
    }

    .task-subtitle {
      display: block;
      margin-top: 3px;
      color: var(--muted);
      font-size: 0.88rem;
    }

    .chevron {
      flex: 0 0 auto;
      color: var(--primary);
      font-size: 1.35rem;
      transition: transform 0.2s ease;
    }

    .task-card[open] .chevron {
      transform: rotate(180deg);
    }

    .task-content {
      padding: 0 18px 18px 72px;
      border-top: 1px solid var(--border);
    }

    .task-content p {
      margin: 16px 0 0;
    }

    .note {
      margin-top: 14px;
      padding: 10px 12px;
      border-radius: 12px;
      background: var(--primary-light);
      color: var(--primary);
      font-weight: 700;
    }

    .answer-box {
      margin-top: 16px;
    }

    .answer-box label {
      display: block;
      margin-bottom: 8px;
      font-weight: 700;
    }

    .task-answer {
      width: 100%;
      min-height: 92px;
      padding: 12px 14px;
      border: 1px solid #cfcfd6;
      border-radius: 12px;
      background: #ffffff;
      color: var(--text);
      font: inherit;
      line-height: 1.5;
      resize: vertical;
    }

    .task-answer.short-answer {
      min-height: 52px;
      resize: none;
    }

    .task-answer:focus {
      outline: 3px solid rgba(111, 45, 189, 0.18);
      border-color: var(--primary);
    }

    .task-answer.too-many-words {
      border-color: var(--danger);
      background: var(--danger-light);
    }

    .answer-info {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      margin-top: 6px;
      color: var(--muted);
      font-size: 0.88rem;
    }

    .word-counter {
      margin-left: auto;
      white-space: nowrap;
    }

    .word-counter.limit-reached {
      color: var(--danger);
      font-weight: 700;
    }

    .limit-warning {
      display: none;
      margin-top: 8px;
      padding: 9px 11px;
      border-radius: 10px;
      background: var(--danger-light);
      color: var(--danger);
      font-size: 0.9rem;
      font-weight: 700;
    }

    .limit-warning.show {
      display: block;
    }


    .photo-box {
      margin-top: 16px;
      padding: 14px;
      border: 1px solid var(--border);
      border-radius: 14px;
      background: #fafafa;
    }

    .photo-title {
      display: block;
      margin-bottom: 10px;
      font-weight: 700;
    }

    .photo-input {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      clip-path: inset(50%);
    }

    .photo-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      min-height: 48px;
      padding: 11px 14px;
      border: 0;
      border-radius: 12px;
      background: var(--primary);
      color: #ffffff;
      font-weight: 700;
      cursor: pointer;
      text-align: center;
    }

    .photo-choice {
      display: grid;
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .photo-button-secondary {
      background: #ffffff;
      color: var(--primary);
      border: 1px solid var(--primary);
    }

    .photo-button:active {
      transform: translateY(1px);
    }

    .photo-help {
      margin: 8px 0 0;
      color: var(--muted);
      font-size: 0.88rem;
    }

    .photo-preview-wrap {
      display: none;
      margin-top: 12px;
    }

    .photo-preview-wrap.has-photo {
      display: block;
    }

    .photo-preview {
      display: block;
      width: 100%;
      max-height: 360px;
      object-fit: contain;
      border-radius: 12px;
      background: #ececf0;
    }

    .photo-actions {
      display: flex;
      gap: 10px;
      margin-top: 10px;
    }

    .photo-delete {
      width: 100%;
      min-height: 44px;
      padding: 9px 12px;
      border: 1px solid var(--danger);
      border-radius: 11px;
      background: #ffffff;
      color: var(--danger);
      font-weight: 700;
      cursor: pointer;
    }

    .photo-status {
      margin-top: 8px;
      color: var(--muted);
      font-size: 0.88rem;
    }

    .photo-status.saved {
      color: var(--success);
      font-weight: 700;
    }

    .photo-status.error {
      color: var(--danger);
      font-weight: 700;
    }

    .complete-label {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-top: 18px;
      padding-top: 14px;
      border-top: 1px dashed var(--border);
      color: var(--success);
      font-weight: 700;
      cursor: pointer;
    }

    .complete-label input {
      width: 22px;
      height: 22px;
      accent-color: var(--success);
    }

    .complete-label.is-disabled {
      color: #8a8d93;
      cursor: not-allowed;
    }

    .complete-label input:disabled {
      cursor: not-allowed;
    }


    .team-card,
    .submit-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 20px;
      margin-bottom: 18px;
      box-shadow: 0 4px 14px rgba(0, 0, 0, 0.06);
    }

    .team-card h2,
    .submit-card h2 {
      margin: 0 0 8px;
      font-size: 1.35rem;
    }

    .section-intro {
      margin: 0 0 16px;
      color: var(--muted);
    }

    .form-field {
      margin-top: 14px;
    }

    .form-field label {
      display: block;
      margin-bottom: 7px;
      font-weight: 700;
    }

    .form-input {
      width: 100%;
      min-height: 48px;
      padding: 11px 13px;
      border: 1px solid #cfcfd6;
      border-radius: 12px;
      background: #ffffff;
      color: var(--text);
      font: inherit;
    }

    .form-input:focus {
      outline: 3px solid rgba(111, 45, 189, 0.18);
      border-color: var(--primary);
    }

    .summary-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin: 16px 0;
    }

    .summary-item {
      padding: 12px 8px;
      border-radius: 12px;
      background: #f6f1fc;
      text-align: center;
    }

    .summary-number {
      display: block;
      font-size: 1.35rem;
      font-weight: 800;
      color: var(--primary);
    }

    .summary-label {
      display: block;
      margin-top: 2px;
      color: var(--muted);
      font-size: 0.82rem;
    }

    .submit-button {
      width: 100%;
      min-height: 52px;
      padding: 12px 16px;
      border: 0;
      border-radius: 13px;
      background: var(--primary);
      color: #ffffff;
      font-weight: 800;
      cursor: pointer;
    }

    .submit-button:disabled {
      background: #a9abb2;
      cursor: wait;
    }


    .pre-submit-summary {
      display: none;
      margin-top: 16px;
      padding: 15px;
      border: 1px solid rgba(111, 45, 189, 0.28);
      border-radius: 14px;
      background: #fbf8ff;
    }

    .pre-submit-summary.show {
      display: block;
    }

    .pre-submit-summary h3 {
      margin: 0 0 10px;
      font-size: 1.08rem;
    }

    .pre-submit-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-bottom: 12px;
    }

    .pre-submit-item {
      padding: 10px;
      border-radius: 11px;
      background: #ffffff;
      text-align: center;
    }

    .pre-submit-number {
      display: block;
      font-size: 1.25rem;
      font-weight: 900;
      color: var(--primary);
    }

    .pre-submit-label {
      display: block;
      margin-top: 2px;
      color: var(--muted);
      font-size: 0.8rem;
    }

    .missing-tasks {
      margin: 8px 0 0;
      padding-left: 20px;
    }

    .missing-tasks li {
      margin-bottom: 5px;
    }

    .summary-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 14px;
    }

    .secondary-button {
      min-height: 48px;
      padding: 10px 14px;
      border: 1px solid var(--primary);
      border-radius: 11px;
      background: #ffffff;
      color: var(--primary);
      font-weight: 800;
    }

    @media (max-width: 520px) {
      .pre-submit-grid,
      .summary-actions {
        grid-template-columns: 1fr;
      }
    }

    .submit-status {
      display: none;
      margin-top: 14px;
      padding: 12px;
      border-radius: 12px;
      font-weight: 700;
    }

    .submit-status.show {
      display: block;
    }

    .submit-status.working {
      background: #eef3ff;
      color: #2451a6;
    }

    .submit-status.success {
      background: #e7f6eb;
      color: var(--success);
    }

    .submit-status.error {
      background: var(--danger-light);
      color: var(--danger);
    }

    .receipt {
      margin-top: 8px;
      font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
      overflow-wrap: anywhere;
    }

    .privacy-note {
      margin: 12px 0 0;
      color: var(--muted);
      font-size: 0.86rem;
    }

    @media (max-width: 520px) {
      .summary-grid {
        grid-template-columns: 1fr;
      }
    }


    .app-locked .team-card,
    .app-locked .task-card,
    .app-locked .submit-card {
      opacity: 0.92;
    }

    .app-locked input,
    .app-locked textarea,
    .app-locked .photo-button,
    .app-locked .photo-delete,
    .app-locked .submit-button {
      pointer-events: none;
    }

    .locked-banner {
      display: none;
      margin-bottom: 18px;
      padding: 16px;
      border-radius: 16px;
      background: #e7f6eb;
      color: var(--success);
      font-weight: 700;
      box-shadow: 0 4px 14px rgba(0, 0, 0, 0.05);
    }

    .locked-banner.show {
      display: block;
    }

    .locked-banner strong {
      display: block;
      margin-bottom: 4px;
      font-size: 1.05rem;
    }

    .new-game-button {
      display: none;
      width: 100%;
      min-height: 48px;
      margin-top: 12px;
      padding: 11px 14px;
      border: 1px solid var(--danger);
      border-radius: 12px;
      background: #ffffff;
      color: var(--danger);
      font-weight: 800;
      cursor: pointer;
    }

    .new-game-button.show {
      display: block;
    }

    .footer {
      margin-top: 22px;
      text-align: center;
      color: var(--muted);
      font-size: 0.9rem;
    }

    @media (max-width: 520px) {
      .hero {
        padding: 20px;
      }

      .task-summary {
        padding: 16px;
      }

      .task-content {
        padding: 0 16px 16px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      * {
        scroll-behavior: auto !important;
        transition: none !important;
      }
    }

    /* =========================================
       TROPICKÝ REALITY-SHOW VZHLED – pouze design
       ========================================= */
    :root {
      --bg: #f4eedf;
      --card: rgba(255, 253, 247, 0.97);
      --text: #202821;
      --muted: #667068;
      --primary: #244f38;
      --primary-light: #e5ede4;
      --border: rgba(45, 65, 50, 0.20);
      --success: #2e6b3d;
      --danger: #a53224;
      --danger-light: #f9ece8;
      --sand: #d8c59d;
      --orange: #d97b25;
      --jungle: #173f2a;
      --cream: #fffaf0;
    }

    body {
      position: relative;
      min-height: 100vh;
      overflow-x: hidden;
      background:
        linear-gradient(rgba(248, 244, 234, 0.92), rgba(239, 229, 207, 0.96)),
        repeating-linear-gradient(110deg, rgba(82, 69, 48, 0.025) 0 1px, transparent 1px 9px),
        #eee4cf;
      color: var(--text);
    }

    body::before {
      content: "";
      position: fixed;
      z-index: -1;
      top: 0;
      left: 50%;
      width: min(1400px, 120vw);
      height: 246px;
      transform: translateX(-50%);
      background: url("data:image/png;base64,") top center / contain no-repeat;
      opacity: 0.78;
      pointer-events: none;
      filter: saturate(0.82) contrast(1.04) drop-shadow(0 14px 18px rgba(20, 45, 28, 0.16));
    }

    .page {
      position: relative;
      padding-top: 62px;
    }

    .hero {
      position: relative;
      isolation: isolate;
      overflow: hidden;
      min-height: 300px;
      padding: 34px 30px 28px;
      border: 1px solid rgba(28, 62, 41, 0.34);
      border-radius: 10px;
      background:
        linear-gradient(115deg, rgba(255, 251, 239, 0.98) 0 58%, rgba(241, 224, 184, 0.94) 100%),
        #f4ead3;
      box-shadow:
        0 18px 38px rgba(38, 48, 38, 0.18),
        inset 0 1px 0 rgba(255,255,255,0.9);
    }

    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: -2;
      background:
        linear-gradient(90deg, rgba(23,63,42,0.08) 1px, transparent 1px),
        linear-gradient(rgba(23,63,42,0.06) 1px, transparent 1px);
      background-size: 34px 34px;
      mask-image: linear-gradient(to right, rgba(0,0,0,0.45), transparent 72%);
      pointer-events: none;
    }

    .hero::after {
      content: "";
      position: absolute;
      z-index: -1;
      right: -34px;
      bottom: -12px;
      width: min(48%, 320px);
      aspect-ratio: 629 / 288;
      background: url("data:image/png;base64,") center / contain no-repeat;
      opacity: 0.78;
      filter: saturate(0.80) contrast(1.02) drop-shadow(0 12px 10px rgba(55, 36, 18, 0.22));
      pointer-events: none;
    }

    h1 {
      position: relative;
      z-index: 1;
      max-width: 72%;
      margin: 0 0 18px;
      color: var(--jungle);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(2.3rem, 8vw, 3.7rem);
      font-weight: 900;
