    function getCompetitionDeadline() {
      return new Date("2026-07-21T17:30:00+02:00");
    }

    function formatCountdown(milliseconds) {
      const totalSeconds = Math.max(
        0,
        Math.floor(milliseconds / 1000)
      );

      const hours = Math.floor(totalSeconds / 3600);
      const minutes = Math.floor(
        (totalSeconds % 3600) / 60
      );
      const seconds = totalSeconds % 60;

      return [hours, minutes, seconds]
        .map(value => String(value).padStart(2, "0"))
        .join(":");
    }

    function updateCountdown() {
      const now = new Date();
      const deadline = getCompetitionDeadline();
      const difference = deadline.getTime() - now.getTime();

      if (difference <= 0) {
        countdownTime.textContent = "ČAS VYPRŠEL";
        countdownBox.classList.add("expired");
        return;
      }

      countdownTime.textContent = formatCountdown(difference);
      countdownBox.classList.remove("expired");
    }

